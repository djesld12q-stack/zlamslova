        string custom = CustomHistoryPath?.Trim() ?? "";
        return !string.IsNullOrEmpty(custom) ? custom : DefaultHistoryPath;
    }

    private void AddMessageToHistory(string user, string message)
    {
        if (string.IsNullOrWhiteSpace(message))
            return;
        var history = UserMessageHistory.GetOrAdd(user, _ => new List<string>());
        lock (history)
        {
            history.Insert(0, message);
            if (history.Count > MaxHistoryPerUser)
                history.RemoveAt(history.Count - 1);
        }
    }

    private async Task<string> FindBrokenMessageInHistoryAsync(string user)
    {
        if (!UserMessageHistory.TryGetValue(user, out var history))
        {
            if (LogFixes)
                CPH.LogWarn($"[BotBandera] Немає історії для '{user}'");
            return null;
        }

        List<string> snapshot;
        lock (history)
        {
            snapshot = history.Take(15).ToList();
        }

        if (snapshot.Count == 0)
        {
            if (LogFixes)
                CPH.LogWarn("[BotBandera] Історія порожня");
            return null;
        }

        foreach (var candidate in snapshot)
        {
            if (string.IsNullOrWhiteSpace(candidate) || candidate.StartsWith("!"))
                continue;
            var(isBroken, _) = await IsBrokenAndFixAsync(candidate);
            if (isBroken)
            {
                lock (history)
                {
                    history.Remove(candidate);
                }

                return candidate;
            }
        }

        if (LogFixes)
            CPH.LogWarn("[BotBandera] Ламаного не знайдено");
        return null;
    }

    public bool Execute()
    {
        InitDefaults();
        CPH.TryGetArg("triggerId", out string triggerId);
        if (triggerId == "410aa862-165d-437f-a36b-d8855aca5073")
        {
            ShowSettingsWindow();
            return true;
        }

        string rawInput = args["rawInput"]?.ToString() ?? "";
        string user = args["user"]?.ToString() ?? args["userName"]?.ToString() ?? "unknown";
        if (LogFixes)
            CPH.LogInfo($"\n════ INPUT ════\nUser: {user}\nText: '{rawInput}'");
        _ = CheckForNewerVersionAsync(announceInChat: false);
        if (string.IsNullOrWhiteSpace(rawInput) || (StopBots && BotNames.Contains(user.ToLowerInvariant())))
            return true;
        string msg = rawInput.Trim();
        if (!msg.StartsWith("!"))
        {
            AddMessageToHistory(user, rawInput);
            if (LogFixes)
                CPH.LogInfo("[BotBandera] ➕ Історія");
            return true;
        }

        var(matched, inlineText) = TryMatchTrigger(msg);
        if (matched)
            _ = HandleTriggerAsync(inlineText, user);
        return true;
    }

    private (bool Matched, string InlineText) TryMatchTrigger(string msg)
    {
        if (string.IsNullOrWhiteSpace(Triggers))
            return (false, null);
        string msgLower = msg.ToLowerInvariant();
        foreach (string raw in Triggers.Split(',').Select(t => t.Trim().ToLowerInvariant()).Where(t => t.Length > 0))
        {
            string normal = raw.StartsWith("!") ? raw : "!" + raw;
            string broken = ConvertEnToUk(normal);
            if (msgLower == normal || msgLower == broken)
                return (true, null);
            if (msgLower.StartsWith(normal + " "))
                return (true, msg.Substring(normal.Length + 1).Trim());
            if (msgLower.StartsWith(broken + " "))
                return (true, msg.Substring(broken.Length + 1).Trim());
        }

        return (false, null);
    }

    private async Task HandleTriggerAsync(string inlineText, string user)
    {
        try
        {
            if (inlineText != null)
            {
                await ProcessFixRequestAsync(inlineText, user);
                return;
            }

            string found = await FindBrokenMessageInHistoryAsync(user);
            if (found != null)
            {
                await ProcessFixRequestAsync(found, user);
            }
            else
            {
                if (LogFixes)
                    CPH.LogWarn("[BotBandera] Ламаного повідомлення не знайдено при активації тригера");
                CPH.SendMessage(T("NoBrokenFound").Replace("{user}", user));
            }
        }
        catch (Exception ex)
        {
            if (LogFixes)
                CPH.LogError($"[BotBandera] Помилка обробки тригера: {ex.Message}");
        }
    }

    private async Task ProcessFixRequestAsync(string input, string user)
    {
        string original = input.Trim();
        if (original.Length < 1)
            return;
        if (IgnoreRussianMessages && ContainsRussianLetters(original))
            return;
        var(isBroken, fixedText) = await IsBrokenAndFixAsync(original);
        if (!isBroken)
        {
            if (LogFixes)
                CPH.LogInfo("[BotBandera] Текст не визначено як зламаний розклад");
            return;
        }

        SaveToHistory(original);
        if (!string.IsNullOrWhiteSpace(ResponseTemplate))
            SendResponse(user, fixedText);
    }

    private bool ContainsRussianLetters(string text) => text.IndexOfAny(CustomRussianLetters.ToCharArray()) >= 0;
    private bool IsLatinOnly(string word) => word.All(c => (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || c == '-' || c == '.' || c == '\'');
    private string FixTextPreserve(string input, Regex regex)
    {
        var sb = new StringBuilder();
        int pos = 0;
        foreach (Match m in regex.Matches(input))
        {
            sb.Append(ConvertEnToUk(input.Substring(pos, m.Index - pos)));
            sb.Append(m.Value);
            pos = m.Index + m.Length;
        }

        sb.Append(ConvertEnToUk(input.Substring(pos)));
        return sb.ToString().Trim();
    }

    private string ConvertEnToUk(string input)
    {
        var sb = new StringBuilder();
        foreach (char c in input)
            sb.Append(EnToUk.TryGetValue(c, out char mapped) ? mapped : c);
        return sb.ToString();
    }

    private void SendResponse(string user, string fixedText)
    {
        string message = ResponseTemplate.Replace("{user}", user).Replace("{fixed}", fixedText);
        if (!string.IsNullOrWhiteSpace(ResponseEmoji))
            message = ResponseEmoji + " " + message;
        if (LogFixes)
            CPH.LogInfo($"[BotBandera] ✅ '{fixedText}'");
        if (message.Length <= 495)
            CPH.SendMessage(message);
        else
        {
            CPH.SendMessage(message.Substring(0, 495) + "...");
            foreach (string part in SplitLong(fixedText))
                CPH.SendMessage(part);
        }
    }

    private IEnumerable<string> SplitLong(string text)
    {
        for (int i = 0; i < text.Length; i += 485)
            yield return text.Substring(i, Math.Min(485, text.Length - i));
    }

    private void SaveToHistory(string phrase)
    {
        if (!SaveHistory || MaxHistory <= 0)
            return;
        string path = GetHistoryPath();
        lock (BrokenHistory)
        {
            string entry = $"[{DateTime.Now:yyyy-MM-dd HH:mm}] {phrase}";
            if (BrokenHistory.Contains(entry))
                return;
            BrokenHistory.Insert(0, entry);
            if (BrokenHistory.Count > MaxHistory)
                BrokenHistory.RemoveRange(MaxHistory, BrokenHistory.Count - MaxHistory);
            Task.Run(() =>
            {
                try
                {
                    Directory.CreateDirectory(System.IO.Path.GetDirectoryName(path) ?? "");
                    File.WriteAllLines(path, BrokenHistory, Encoding.UTF8);
                }
                catch
                {
                }
            });
        }
    }

