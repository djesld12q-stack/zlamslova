                    if (clientId != null)
                        msg.Headers.Add("Client-Id", clientId);
                    if (forceRefresh)
                        msg.Headers.CacheControl = new System.Net.Http.Headers.CacheControlHeaderValue
                        {
                            NoCache = true,
                            NoStore = true
                        };
                    using var cts = new CancellationTokenSource(10000);
                    var resp = await client.SendAsync(msg, cts.Token);
                    if (!resp.IsSuccessStatusCode)
                    {
                        if (LogFixes)
                            CPH.LogWarn($"[BotBandera] ⚠️ {label}: HTTP {(int)resp.StatusCode}");
                        return;
                    }

                    string body = await resp.Content.ReadAsStringAsync();
                    int found = 0;
                    foreach (Match m in fieldRegex.Matches(body))
                    {
                        string name = Regex.Unescape(m.Groups[1].Value);
                        if (name.Length > 0 && !name.Contains(' '))
                        {
                            lock (names)
                            {
                                if (names.Add(name))
                                    found++;
                            }
                        }
                    }

                    if (LogFixes)
                        CPH.LogInfo($"[BotBandera] ✅ {label}: +{found}");
                }
                catch (Exception ex)
                {
                    if (LogFixes)
                        CPH.LogWarn($"[BotBandera] ⚠️ {label}: {ex.Message}");
                }
            }

            string broadcasterId = null;
            try
            {
                broadcasterId = CPH.TwitchGetBroadcaster()?.UserId;
            }
            catch
            {
            }

            var tasks = new List<Task>();
            string token = CPH.TwitchOAuthToken;
            string clientId = CPH.TwitchClientId;
            if (!string.IsNullOrWhiteSpace(token) && !string.IsNullOrWhiteSpace(clientId))
            {
                tasks.Add(FetchAsync(TwitchHelixClient, "emotes/global", "Twitch глобальні", EmoteNameJsonRegex, token, clientId));
                var setIds = ExtraEmoteSetIds.Split(',').Select(s => s.Trim()).Where(s => s.Length > 0).ToList();
                foreach (var e in await GetRemoteListAsync(RemoteEmotesFile, "Емоути (репозиторій)", forceRefresh))
                    if (e.All(char.IsDigit) && !setIds.Contains(e))
                        setIds.Add(e);
                for (int i = 0; i < setIds.Count; i += 10)
                {
                    string q = string.Join("&", setIds.Skip(i).Take(10).Select(id => "emote_set_id=" + Uri.EscapeDataString(id)));
                    tasks.Add(FetchAsync(TwitchHelixClient, $"emotes/set?{q}", "Twitch emote set", EmoteNameJsonRegex, token, clientId));
                }
            }
            else if (LogFixes)
                CPH.LogWarn("[BotBandera] ⚠️ Немає Twitch OAuth токена — Twitch Helix емоути пропущено");
            tasks.Add(FetchAsync(BttvClient, "cached/emotes/global", "BTTV глобальні", EmoteCodeJsonRegex));
            if (!string.IsNullOrWhiteSpace(broadcasterId))
                tasks.Add(FetchAsync(BttvClient, $"cached/users/twitch/{broadcasterId}", "BTTV канальні", EmoteCodeJsonRegex));
            tasks.Add(FetchAsync(FfzClient, "set/global", "FFZ глобальні", EmoteNameJsonRegex));
            if (!string.IsNullOrWhiteSpace(broadcasterId))
                tasks.Add(FetchAsync(FfzClient, $"room/id/{broadcasterId}", "FFZ канальні", EmoteNameJsonRegex));
            tasks.Add(FetchAsync(SevenTvClient, "emote-sets/global", "7TV глобальні", EmoteNameJsonRegex));
            if (!string.IsNullOrWhiteSpace(broadcasterId))
                tasks.Add(FetchAsync(SevenTvClient, $"users/twitch/{broadcasterId}", "7TV канальні", EmoteNameJsonRegex));
            await Task.WhenAll(tasks);
            _emoteNamesCache = names;
            _emoteNamesLoadedAt = DateTime.UtcNow;
            PersistEmoteNamesCache(names);
            if (LogFixes)
                CPH.LogInfo($"[BotBandera] 🎉 Разом емоутів (Twitch+BTTV+FFZ+7TV): {names.Count}");
            return names;
        }
        finally
        {
            _emoteLock.Release();
        }
    }

