    private WrapPanel MakeChips(params (string v, string d)[] items)
    {
        var wp = new WrapPanel
        {
            Margin = new Thickness(0, 0, 0, 18)
        };
        foreach (var(v, d)in items)
            wp.Children.Add(MakeChip(v, d));
        return wp;
    }

    private void UpdateEmoteChips(WrapPanel panel, IEnumerable<string> names)
    {
        panel.Children.Clear();
        var list = names.OrderBy(n => n, StringComparer.OrdinalIgnoreCase).ToList();
        int shown = Math.Min(40, list.Count);
        for (int i = 0; i < shown; i++)
        {
            var chip = new Border
            {
                CornerRadius = new CornerRadius(5),
                Background = new SolidColorBrush(Color.FromArgb(30, 70, 170, 255)),
                BorderBrush = new SolidColorBrush(Color.FromArgb(60, 70, 170, 255)),
                BorderThickness = new Thickness(1),
                Padding = new Thickness(8, 3, 8, 3),
                Margin = new Thickness(0, 0, 6, 6)
            };
            chip.Child = new TextBlock
            {
                Text = list[i],
                FontSize = 11,
                FontFamily = new FontFamily("Consolas"),
                Foreground = new SolidColorBrush(TextMain)
            };
            panel.Children.Add(chip);
        }

        if (list.Count > shown)
        {
            var more = new Border
            {
                CornerRadius = new CornerRadius(5),
                Background = new SolidColorBrush(Color.FromArgb(20, 200, 200, 200)),
                Padding = new Thickness(8, 3, 8, 3),
                Margin = new Thickness(0, 0, 6, 6)
            };
            more.Child = new TextBlock
            {
                Text = $"+{list.Count - shown} ще",
                FontSize = 11,
                Foreground = new SolidColorBrush(TextMuted)
            };
            panel.Children.Add(more);
        }
    }

