    private async Task<Regex> GetPreserveRegexAsync()
    {
        var allNames = new HashSet<string>(PreserveEmotesList.Split(',').Select(e => e.Trim()).Where(e => e.Length > 0 && !e.All(char.IsDigit)), StringComparer.OrdinalIgnoreCase);
        var protectedWordsTask = GetProtectedWordsAsync();
        var repoEmotesTask = GetRemoteListAsync(RemoteEmotesFile, "Емоути (репозиторій)");
        var twitchEmotesTask = UseTwitchEmotesApi ? GetAllEmoteNamesAsync() : Task.FromResult(new HashSet<string>(StringComparer.OrdinalIgnoreCase));
        await Task.WhenAll(protectedWordsTask, repoEmotesTask, twitchEmotesTask);
        foreach (var w in protectedWordsTask.Result)
            allNames.Add(w);
        foreach (var e in repoEmotesTask.Result)
            if (e.Length > 0 && !e.All(char.IsDigit))
                allNames.Add(e);
        foreach (var n in twitchEmotesTask.Result)
            allNames.Add(n);
        var escaped = allNames.Select(Regex.Escape).ToList();
        var pattern = escaped.Count > 0 ? $@"(?<!\w)({string.Join("|", escaped)})(?!\w)|:\w+:|<a?:\w+:\d+>|https?://\S+|@\w+|#\w+|\d+|\S+@\S+\.\S+" : @":\w+:|<a?:\w+:\d+>|https?://\S+|@\w+|#\w+|\d+|\S+@\S+\.\S+";
        return new Regex(pattern, RegexOptions.Compiled | RegexOptions.IgnoreCase);
    }

