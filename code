    private static bool IsUkrainianCyrillic(char c)
    {
        return (c >= 'а' && c <= 'я') || (c >= 'А' && c <= 'Я') || c == 'і' || c == 'І' || c == 'ї' || c == 'Ї' || c == 'є' || c == 'Є' || c == 'ґ' || c == 'Ґ';
    }

    private static bool IsAllUkrainianCyrillic(string s) => s.Length > 0 && s.All(IsUkrainianCyrillic);
    private bool IsWordBroken(string converted, HashSet<string> dict, HashSet<string> ultraTriggers)
    {
        if (string.IsNullOrEmpty(converted) || converted.Length < 2)
            return false;
        string low = converted.ToLowerInvariant();
        if (ultraTriggers.Contains(low))
            return true;
        if (dict.Contains(low))
            return true;
        if (low.Length >= 2 && low.Length <= 5 && IsAllUkrainianCyrillic(low))
            return true;
        if (low.Length >= 3)
        {
            foreach (var w in dict)
            {
                if (w.Length >= low.Length && w.StartsWith(low, StringComparison.OrdinalIgnoreCase))
                    return true;
            }
        }

        if (low.Length >= 4)
        {
            foreach (var w in dict)
            {
                if (Math.Abs(w.Length - low.Length) > 2)
                    continue;
                if (LevenshteinDistance(low, w) <= 1)
                    return true;
            }
        }

        return false;
    }

    private static int LevenshteinDistance(string a, string b)
    {
        if (a.Length == 0)
            return b.Length;
        if (b.Length == 0)
            return a.Length;
        if (a.Length > 12 || b.Length > 12)
            return Math.Abs(a.Length - b.Length) + 1;
        var d = new int[a.Length + 1, b.Length + 1];
        for (int i = 0; i <= a.Length; i++)
            d[i, 0] = i;
        for (int j = 0; j <= b.Length; j++)
            d[0, j] = j;
        for (int i = 1; i <= a.Length; i++)
            for (int j = 1; j <= b.Length; j++)
                d[i, j] = Math.Min(Math.Min(d[i - 1, j] + 1, d[i, j - 1] + 1), d[i - 1, j - 1] + (a[i - 1] == b[j - 1] ? 0 : 1));
        return d[a.Length, b.Length];
    }

    private async Task<(bool IsBroken, string FixedText)> IsBrokenAndFixAsync(string text)
    {
        if (string.IsNullOrWhiteSpace(text))
            return (false, text);
        var preserveRegexTask = GetPreserveRegexAsync();
        var ultraTriggersTask = GetUltraTriggersAsync();
        var gamerSlangTask = GetGamerSlangAsync();
        await Task.WhenAll(preserveRegexTask, ultraTriggersTask, gamerSlangTask);
        var preserveRegex = preserveRegexTask.Result;
        var ultraTriggers = ultraTriggersTask.Result;
        var gamerSlang = gamerSlangTask.Result;
        var allMatches = WordRegex.Matches(text).Cast<Match>().Where(m => !preserveRegex.IsMatch(m.Value)).Select(m => m.Value).Where(w => w.Length >= 1).ToList();
        if (allMatches.Count == 0)
            return (false, text);
        var latinWords = allMatches.Where(w => IsLatinOnly(w)).Select(w => w.ToLowerInvariant()).Where(w => !gamerSlang.Contains(w)).ToList();
        var cyrillicWords = allMatches.Where(w => !IsLatinOnly(w)).Select(w => w.ToLowerInvariant()).Where(w => !gamerSlang.Contains(w)).ToList();
        if (latinWords.Count == 0)
            return (false, text);
        var convertedLatin = latinWords.Select(w => ConvertEnToUk(w).ToLowerInvariant()).ToList();
        // ── Крок 1: UltraTriggers — точний збіг, без словника ──
        bool ultraHit = convertedLatin.Any(w => ultraTriggers.Contains(w));
        if (ultraHit)
        {
            if (LogFixes)
                CPH.LogInfo($"[BotBandera] ⚡ UltraTrigger!");
            return (true, FixTextPreserve(text, preserveRegex));
        }

        int shortCyrillicCount = convertedLatin.Count(w => w.Length >= 2 && w.Length <= 5 && IsAllUkrainianCyrillic(w));
        if (shortCyrillicCount > 0)
        {
            bool hasEnglishContext = cyrillicWords.Count > 0 ? false : latinWords.Any(w => IsCommonEnglishWord(w));
            if (!hasEnglishContext)
            {
                if (LogFixes)
                    CPH.LogInfo($"[BotBandera] ⚡ ShortWord hit! ({shortCyrillicCount} слів)");
                return (true, FixTextPreserve(text, preserveRegex));
            }
        }

        var dict = await GetDictionaryAsync();
        int ukrConverted = convertedLatin.Count(w => IsWordBroken(w, dict, ultraTriggers));
        int ukrOriginal = cyrillicWords.Count(w => dict.Contains(w));
        int engInDict = latinWords.Count(w => dict.Contains(w));
        int totalWords = latinWords.Count + cyrillicWords.Count;
        if (LogFixes)
            CPH.LogInfo($"[BotBandera] 📊 total={totalWords}, latin={latinWords.Count}, " + $"converted=[{string.Join(", ", convertedLatin)}], " + $"ukrConverted(fuzzy)={ukrConverted}, ukrOriginal={ukrOriginal}, engInDict={engInDict}");
        bool isBroken;
        int ukrOriginalTotal = ukrOriginal + engInDict;
        if (totalWords == 1)
        {
            isBroken = ukrConverted >= 1 && engInDict == 0;
        }
        else if (latinWords.Count == totalWords)
        {
            // Всі латинські: достатньо 1 fuzzy збігу
            isBroken = ukrConverted >= 1;
        }
        else
        {
            isBroken = ukrConverted > ukrOriginalTotal;
        }

        if (LogFixes)
            CPH.LogInfo($"[BotBandera] 🔍 isBroken={isBroken}");
        return isBroken ? (true, FixTextPreserve(text, preserveRegex)) : (false, text);
    }

