    private static HashSet<string> _dictionaryCache = null;
    private static DateTime _dictionaryLoadedAt = DateTime.MinValue;
    private static readonly SemaphoreSlim _dictLock = new SemaphoreSlim(1, 1);
    private const int DictionaryCacheHours = 24;
    private async Task<HashSet<string>> GetDictionaryAsync()
    {
        if (_dictionaryCache != null && (DateTime.UtcNow - _dictionaryLoadedAt).TotalHours < DictionaryCacheHours)
            return _dictionaryCache;
        await _dictLock.WaitAsync();
        try
        {
            if (_dictionaryCache != null && (DateTime.UtcNow - _dictionaryLoadedAt).TotalHours < DictionaryCacheHours)
                return _dictionaryCache;
            if (LogFixes)
                CPH.LogInfo("[BotBandera] 📥 Завантажую словник...");
            using var cts = new CancellationTokenSource(15000);
            var response = await UkrainianClient.GetAsync("ukrainian-words.txt", cts.Token);
            if (!response.IsSuccessStatusCode)
            {
                if (LogFixes)
                    CPH.LogWarn($"[BotBandera] ❌ Словник недоступний: {response.StatusCode}");
                return _dictionaryCache ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            }

            string content = await response.Content.ReadAsStringAsync();
            var words = new HashSet<string>(content.Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries).Select(w => w.Trim().ToLowerInvariant()).Where(w => w.Length >= 2), StringComparer.OrdinalIgnoreCase);
            _dictionaryCache = words;
            _dictionaryLoadedAt = DateTime.UtcNow;
            if (LogFixes)
                CPH.LogInfo($"[BotBandera] ✅ Словник: {words.Count} слів");
            return words;
        }
        catch (Exception ex)
        {
            if (LogFixes)
                CPH.LogError($"[BotBandera] Помилка словника: {ex.Message}");
            return _dictionaryCache ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        }
        finally
        {
            _dictLock.Release();
        }
    }

