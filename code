        };
        inner.Children.Add(new TextBlock { Text = v, FontSize = 12, FontFamily = new FontFamily("Consolas"), FontWeight = FontWeights.Bold, Foreground = new SolidColorBrush(C_Accent1), Margin = new Thickness(0, 0, 6, 0) });
