    private UIElement MakeChip(string v, string d)
    {
        var chip = new Border
        {
            CornerRadius = new CornerRadius(5),
            Background = new SolidColorBrush(Color.FromArgb(35, 160, 80, 255)),
            BorderBrush = new SolidColorBrush(Color.FromArgb(70, 180, 100, 255)),
            BorderThickness = new Thickness(1),
            Padding = new Thickness(9, 4, 9, 4),
            Margin = new Thickness(0, 0, 7, 7)
        };
