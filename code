    private void SaveElementsIn(DependencyObject parent)
    {
        foreach (var child in LogicalTreeHelper.GetChildren(parent))
        {
            if (child is TextBox tb && tb.Tag != null)
                CPH.SetGlobalVar(tb.Tag.ToString(), tb.Text ?? "", true);
            else if (child is CheckBox cb && cb.Tag != null)
                CPH.SetGlobalVar(cb.Tag.ToString(), cb.IsChecked == true, true);
            else if (child is DependencyObject dep)
                SaveElementsIn(dep);
        }
    }
