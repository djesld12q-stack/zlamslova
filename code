    private bool UseRemoteWordLists => true;

    private void InvalidateRemoteListCache(string endpoint) => _remoteListLoadedAt[endpoint] = DateTime.MinValue;
    private async Task<HashSet<string>> FetchRemoteListAsync(string endpoint, string label, bool bustCache = false)
    {
        try
        {
            string url = bustCache ? endpoint + (endpoint.Contains("?") ? "&" : "?") + "_cb=" + DateTime.UtcNow.Ticks : endpoint;
            using var cts = new CancellationTokenSource(15000);
            using var reqMsg = new HttpRequestMessage(HttpMethod.Get, url);
            if (bustCache)
            {
                reqMsg.Headers.CacheControl = new System.Net.Http.Headers.CacheControlHeaderValue
                {
                    NoCache = true,
                    NoStore = true,
                    MustRevalidate = true
                };
                reqMsg.Headers.Pragma.Add(new System.Net.Http.Headers.NameValueHeaderValue("no-cache"));
            }

            var resp = await RemoteListsClient.SendAsync(reqMsg, cts.Token);
            if (!resp.IsSuccessStatusCode)
            {
                if (LogFixes)
                    CPH.LogWarn($"[BotBandera] ⚠️ {label}: HTTP {(int)resp.StatusCode}");
                return null;
            }

            string content = await resp.Content.ReadAsStringAsync();
            var items = new HashSet<string>(content.Split(new[] { '\n', '\r', ',' }, StringSplitOptions.RemoveEmptyEntries).Select(w => w.Trim()).Where(w => w.Length > 0), StringComparer.OrdinalIgnoreCase);
            if (LogFixes)
                CPH.LogInfo($"[BotBandera] ✅ {label}: {items.Count} елементів (репозиторій{(bustCache ? ", live" : "")})");
            return items;
        }
        catch (Exception ex)
        {
            if (LogFixes)
                CPH.LogWarn($"[BotBandera] ⚠️ {label}: {ex.Message}");
            return null;
        }
    }

    private async Task<HashSet<string>> GetRemoteListAsync(string endpoint, string label, bool forceRefresh = false)
    {
        if (!UseRemoteWordLists)
            return new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        _remoteListCache.TryGetValue(endpoint, out var cached);
        if (cached == null && !forceRefresh)
        {
            var persisted = LoadPersistedRemoteListCache(endpoint);
            if (persisted != null)
            {
                _remoteListCache[endpoint] = persisted;
                _remoteListLoadedAt[endpoint] = DateTime.MinValue;
                if (LogFixes)
                    CPH.LogInfo($"[BotBandera] 📦 {label}: {persisted.Count} елементів зі збереженої змінної (миттєво)");
                _ = RefreshRemoteListInBackgroundAsync(endpoint, label);
                return persisted;
            }
        }

        if (!forceRefresh && cached != null && _remoteListLoadedAt.TryGetValue(endpoint, out var loadedAt) && (DateTime.UtcNow - loadedAt).TotalMinutes < RemoteListCacheMinutes)
            return cached;
        await _remoteListLock.WaitAsync();
        try
        {
            _remoteListCache.TryGetValue(endpoint, out cached);
            if (!forceRefresh && cached != null && _remoteListLoadedAt.TryGetValue(endpoint, out loadedAt) && (DateTime.UtcNow - loadedAt).TotalMinutes < RemoteListCacheMinutes)
                return cached;
            var fetched = await FetchRemoteListAsync(endpoint, label, forceRefresh);
            if (fetched != null)
            {
                _remoteListCache[endpoint] = fetched;
                _remoteListLoadedAt[endpoint] = DateTime.UtcNow;
                PersistRemoteListCache(endpoint, fetched);
                return fetched;
            }

            return cached ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        }
        finally
        {
            _remoteListLock.Release();
        }
    }

    private async Task RefreshRemoteListInBackgroundAsync(string endpoint, string label)
    {
        try
        {
            await GetRemoteListAsync(endpoint, label, forceRefresh: true);
        }
        catch (Exception ex)
        {
            if (LogFixes)
                CPH.LogWarn($"[BotBandera] ⚠️ Фоновий рефреш «{label}»: {ex.Message}");
        }
    }

    private void PersistRemoteListCache(string endpoint, HashSet<string> items)
    {
        try
        {
            CPH.SetGlobalVar("BotBanderaFixer_Cache_" + endpoint, string.Join(",", items), true);
        }
        catch
        {
        }
    }

    private HashSet<string> LoadPersistedRemoteListCache(string endpoint)
    {
        try
        {
            string raw = CPH.GetGlobalVar<string>("BotBanderaFixer_Cache_" + endpoint, true);
            if (string.IsNullOrWhiteSpace(raw))
                return null;
            return new HashSet<string>(raw.Split(',').Select(s => s.Trim()).Where(s => s.Length > 0), StringComparer.OrdinalIgnoreCase);
        }
        catch
        {
            return null;
        }
    }

    private async Task<int?> FetchRemoteVersionAsync(bool bustCache = false)
    {
        try
        {
            string url = bustCache ? RemoteVersionFile + "?_cb=" + DateTime.UtcNow.Ticks : RemoteVersionFile;
            using var cts = new CancellationTokenSource(10000);
            using var reqMsg = new HttpRequestMessage(HttpMethod.Get, url);
            if (bustCache)
                reqMsg.Headers.CacheControl = new System.Net.Http.Headers.CacheControlHeaderValue
                {
                    NoCache = true,
                    NoStore = true,
                    MustRevalidate = true
                };
            var resp = await RemoteListsClient.SendAsync(reqMsg, cts.Token);
            if (!resp.IsSuccessStatusCode)
            {
                if (LogFixes)
                    CPH.LogWarn($"[BotBandera] ⚠️ Перевірка версії: HTTP {(int)resp.StatusCode}");
                return null;
            }

            string content = (await resp.Content.ReadAsStringAsync()).Trim();
            if (int.TryParse(content, out int remoteVersion))
                return remoteVersion;
            if (LogFixes)
                CPH.LogWarn($"[BotBandera] ⚠️ Перевірка версії: некоректний вміст файлу version ('{content}')");
            return null;
        }
        catch (Exception ex)
        {
            if (LogFixes)
                CPH.LogWarn($"[BotBandera] ⚠️ Перевірка версії: {ex.Message}");
            return null;
        }
    }

    private async Task<int?> GetRemoteVersionAsync(bool forceRefresh = false)
    {
        if (!forceRefresh && _remoteVersionCache.HasValue && (DateTime.UtcNow - _remoteVersionCheckedAt).TotalMinutes < VersionCheckCacheMinutes)
            return _remoteVersionCache;
        var fetched = await FetchRemoteVersionAsync(forceRefresh);
        if (fetched.HasValue)
        {
            _remoteVersionCache = fetched;
            _remoteVersionCheckedAt = DateTime.UtcNow;
        }

        return _remoteVersionCache;
    }

    private async Task CheckForNewerVersionAsync(bool announceInChat = false)
    {
        var remoteVersion = await GetRemoteVersionAsync();
        if (!remoteVersion.HasValue)
            return;
        if (remoteVersion.Value > CurrentVersion)
        {
            string warning = $"[BotBandera] ⚠️ У репозиторії доступна новіша версія коду: v{remoteVersion.Value} (у Streamer.bot зараз v{CurrentVersion}). " + $"Онови файл .../main/code вручну в редакторі C# (Streamer.bot сам код не перекомпільовує).";
            CPH.LogWarn(warning);
            if (announceInChat && !_versionWarningShownThisSession)
            {
                _versionWarningShownThisSession = true;
                CPH.SendMessage($"🔧 BotBandera: у репозиторії є новіша версія коду (v{remoteVersion.Value} проти v{CurrentVersion} зараз). Потрібно вручну оновити код у Streamer.bot.");
            }
        }
        else if (LogFixes)
        {
            CPH.LogInfo($"[BotBandera] ✅ Версія коду актуальна (v{CurrentVersion}, у репозиторії v{remoteVersion.Value})");
        }
    }

