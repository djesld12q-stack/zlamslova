    private void ApplyThemeToChildren(DependencyObject parent)
    {
        foreach (var child in LogicalTreeHelper.GetChildren(parent))
        {
            if (child is TextBox tb)
            {
                tb.Background = new SolidColorBrush(BgInput);
                tb.Foreground = new SolidColorBrush(TextMain);
                tb.CaretBrush = new SolidColorBrush(_isLightTheme ? C_Accent1 : C_Accent2);
                tb.BorderBrush = new SolidColorBrush(_isLightTheme ? Color.FromArgb(120, 140, 60, 220) : Color.FromArgb(65, 140, 60, 220));
            }
            else if (child is CheckBox cb)
            {
                cb.Foreground = new SolidColorBrush(TextMain);
            }
            else if (child is Border b)
            {
                var bgBrush = b.Background as SolidColorBrush;
                if (bgBrush != null)
                {
                    var c = bgBrush.Color;
                    if (c == C_BgCard || c == L_BgCard)
                        b.Background = new SolidColorBrush(BgCard);
                    else if (c == C_BgInput || c == L_BgInput)
                        b.Background = new SolidColorBrush(BgInput);
                    else if (c.A < 60 && c.B > 100 && c.G < 100)
                        b.Background = new SolidColorBrush(_isLightTheme ? Color.FromArgb(30, 120, 80, 220) : Color.FromArgb(18, 80, 160, 255));
                }

                b.BorderBrush = new SolidColorBrush(TBorder);
            }
            else if (child is TextBlock txtBlock && txtBlock.Foreground is SolidColorBrush sb)
            {
                if (sb.Color == C_TextMain || sb.Color == L_TextMain)
                    txtBlock.Foreground = new SolidColorBrush(TextMain);
                else if (sb.Color == C_TextMuted || sb.Color == L_TextMuted)
                    txtBlock.Foreground = new SolidColorBrush(TextMuted);
            }

            if (child is DependencyObject dep)
                ApplyThemeToChildren(dep);
        }
    }

